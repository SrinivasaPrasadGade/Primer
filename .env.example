DATABASE_URL=postgresql+asyncpg://primer:primer_dev@localhost:5432/primer
REDIS_URL=redis://localhost:6379
GEMINI_API_KEY=

# Signs every JWT. app/config.py ships a placeholder so local dev runs without a
# .env, but that placeholder is public — anything reachable by anyone else must
# set a real value here. Generate one with:  openssl rand -hex 32
JWT_SECRET_KEY=
